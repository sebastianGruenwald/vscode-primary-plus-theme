  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9A8060",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#C9473B"
      }
    },
    {
      "name": "String escape / regexp",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#C8692A"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#C8692A"
      }
    },
    {
      "name": "Language constant (true, false, null)",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#C8692A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Other constant",
      "scope": [
        "constant.other",
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#C8692A"
      }
    },
    {
      "name": "Keyword, control flow",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#1E6A9B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage type (class, function, var, let, const)",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#1E6A9B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#7A6040",
        "fontStyle": ""
      }
    },
    {
      "name": "Function definition",
      "scope": [
        "entity.name.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#8B6914"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call entity.name.function",
        "meta.method-call entity.name.function"
      ],
      "settings": {
        "foreground": "#8B6914"
      }
    },
    {
      "name": "Type, class, interface, enum",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.namespace",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#6B4AA0"
      }
    },
    {
      "name": "HTML / XML tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml"
      ],
      "settings": {
        "foreground": "#C9473B"
      }
    },
    {
      "name": "HTML / XML attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#8B6914"
      }
    },
    {
      "name": "CSS property name",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#8B6914"
      }
    },
    {
      "name": "CSS selector class / id",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#6B4AA0"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#3A2B18"
      }
    },
    {
      "name": "Variable – language (this, self, super)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#1E6A9B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#7A5030"
      }
    },
    {
      "name": "Object property / member access",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#6B4828"
      }
    },
    {
      "name": "Built-in function",
      "scope": [
        "support.function",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#3A8A5C"
      }
    },
    {
      "name": "Built-in type / class",
      "scope": [
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#6B4AA0"
      }
    },
    {
      "name": "Built-in constant",
      "scope": [
        "support.constant"
      ],
      "settings": {
        "foreground": "#C8692A"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.definition.tag",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#9A8060"
      }
    },
    {
      "name": "Template expression braces",
      "scope": [
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#C8692A"
      }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#C8692A"
      }
    },
    {
      "name": "Invalid / deprecated",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C9473B",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown – heading",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#8B6914",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown – bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#C9473B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown – italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#1E6A9B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown – bold italic",
      "scope": [
        "markup.bold markup.italic",
        "markup.italic markup.bold"
      ],
      "settings": {
        "foreground": "#C9473B",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Markdown – inline code",
      "scope": [
        "markup.inline.raw",
        "markup.raw.inline"
      ],
      "settings": {
        "foreground": "#3A8A5C"
      }
    },
    {
      "name": "Markdown – link / URL",
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "meta.link"
      ],
      "settings": {
        "foreground": "#1E6A9B",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown – blockquote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#9A8060",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown – list punctuation",
      "scope": [
        "beginning.punctuation.definition.list.markdown",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#8B6914"
      }
    },
    {
