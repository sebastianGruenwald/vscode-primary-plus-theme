  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9A8470",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#E8746A"
      }
    },
    {
      "name": "String escape / regexp",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#E8975A"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#E8975A"
      }
    },
    {
      "name": "Language constant (true, false, null)",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#E8975A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Other constant",
      "scope": [
        "constant.other",
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#E8975A"
      }
    },
    {
      "name": "Keyword, control flow",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#5BA8D4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage type (class, function, var, let, const)",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#5BA8D4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#A8947A",
        "fontStyle": ""
      }
    },
    {
      "name": "Function definition",
      "scope": [
        "entity.name.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#D4A836"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call entity.name.function",
        "meta.method-call entity.name.function"
      ],
      "settings": {
        "foreground": "#D4A836"
      }
    },
    {
      "name": "Type, class, interface, enum",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.namespace",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#9B7CCF"
      }
    },
    {
      "name": "HTML / XML tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml"
      ],
      "settings": {
        "foreground": "#E8746A"
      }
    },
    {
      "name": "HTML / XML attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#D4A836"
      }
    },
    {
      "name": "CSS property name",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#D4A836"
      }
    },
    {
      "name": "CSS selector class / id",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#9B7CCF"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#E0D5C5"
      }
    },
    {
      "name": "Variable – language (this, self, super)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#5BA8D4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#C8A87A"
      }
    },
    {
      "name": "Object property / member access",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#BDA882"
      }
    },
    {
      "name": "Built-in function",
      "scope": [
        "support.function",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#5BBF84"
      }
    },
    {
      "name": "Built-in type / class",
      "scope": [
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#9B7CCF"
      }
    },
    {
      "name": "Built-in constant",
      "scope": [
        "support.constant"
      ],
      "settings": {
        "foreground": "#E8975A"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.definition.tag",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#9A8470"
      }
    },
    {
      "name": "Template expression braces",
      "scope": [
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#E8975A"
      }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#E8975A"
      }
    },
    {
      "name": "Invalid / deprecated",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#E8746A",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown – heading",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#D4A836",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown – bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#E8746A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown – italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#5BA8D4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown – bold italic",
      "scope": [
        "markup.bold markup.italic",
        "markup.italic markup.bold"
      ],
      "settings": {
        "foreground": "#E8746A",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Markdown – inline code",
      "scope": [
        "markup.inline.raw",
        "markup.raw.inline"
      ],
      "settings": {
        "foreground": "#5BBF84"
      }
    },
    {
      "name": "Markdown – link / URL",
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "meta.link"
      ],
      "settings": {
        "foreground": "#5BA8D4",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown – blockquote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#9A8470",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown – list punctuation",
      "scope": [
        "beginning.punctuation.definition.list.markdown",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#D4A836"
      }
    },
    {
